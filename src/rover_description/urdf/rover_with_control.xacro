<?xml version="1.0" ?>
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- ==================== GEOMETRY AND CONSTANTS ==================== -->
<xacro:property name="pi_const" value="3.14159265"/>

<!-- Body Dimensions -->
<xacro:property name="a" value="0.55663" />   <!-- length (x) -->
<xacro:property name="b" value="0.14044" />   <!-- height (z) -->
<xacro:property name="c" value="0.388"   />   <!-- width  (y) -->

<!-- Wheel Dimensions -->
<xacro:property name="r" value="0.035" />     <!-- wheel radius -->
<xacro:property name="d" value="0.04"  />     <!-- wheel thickness -->

<!-- Offsets -->
<xacro:property name="s1" value="${b/2+r}"/>         <!-- body center z above ground -->
<xacro:property name="s2" value="${a/2-r}"/>         <!-- wheel x offset from body center -->
<xacro:property name="s4" value="${c/2+d/2}"/>       <!-- wheel y offset (left/right) -->

<!-- Camera offsets - Mounted on front face -->
<xacro:property name="camera_x" value="${a/2}"/>           <!-- Front face of rover -->
<xacro:property name="camera_y" value="0"/>                <!-- Centered -->
<xacro:property name="camera_z" value="${b/4}"/>           <!-- Half height of rover -->

<!-- RPLIDAR A1 Dimensions -->
<xacro:property name="lidar_height" value="0.042"/>        <!-- RPLIDAR A1 height (42mm) -->
<xacro:property name="lidar_radius" value="0.048"/>        <!-- RPLIDAR A1 radius (48mm) -->
<xacro:property name="lidar_mount_z" value="${b/2 + 0.015}"/> <!-- Just above body -->

<!-- Material Density -->
<xacro:property name="d1" value="2710.0"/>   <!-- body (aluminium) -->
<xacro:property name="d2" value="2710.0"/>   <!-- wheel -->

<!-- Mass -->
<xacro:property name="m1" value="${d1*a*b*c}"/>
<xacro:property name="m2" value="${d2*pi_const*r*r*d}"/>

<!-- Body Inertia -->
<xacro:property name="Ix_body" value="${(1/12)*m1*(b*b+c*c)}"/>
<xacro:property name="Iy_body" value="${(1/12)*m1*(a*a+b*b)}"/>
<xacro:property name="Iz_body" value="${(1/12)*m1*(a*a+c*c)}"/>

<!-- Wheel Inertia -->
<xacro:property name="Iz_wheel" value="${0.5*m2*r*r}"/>
<xacro:property name="I_wheel"  value="${(1.0/12.0)*m2*(3.0*r*r+d*d)}"/>

<!-- ============================================================== -->
<!-- PREMIUM COLORS                                                -->
<!-- ============================================================== -->
<xacro:property name="body_color" value="0.02 0.02 0.02 1.0"/>           <!-- Deep Black -->
<xacro:property name="body_metallic" value="0.05 0.05 0.05 1.0"/>        <!-- Satin Black -->

<!-- LIDAR - Deep Metallic Burgundy -->
<xacro:property name="lidar_color" value="0.35 0.05 0.08 1.0"/>          <!-- Deep Burgundy -->
<xacro:property name="lidar_top_color" value="0.12 0.12 0.12 1.0"/>      <!-- Dark Gunmetal -->

<!-- CAMERA - Bold Premium Blue -->
<xacro:property name="camera_color" value="0.05 0.25 0.65 1.0"/>         <!-- Bold Premium Blue -->

<!-- WHEELS - Premium Dark Alloy -->
<xacro:property name="wheel_color" value="0.08 0.08 0.08 1.0"/>          <!-- Dark Alloy -->
<xacro:property name="wheel_rim_color" value="0.85 0.85 0.88 1.0"/>      <!-- Premium Silver -->

<!-- Inertia macro: body -->
<xacro:macro name="inertia_body">
    <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="${m1}"/>
        <inertia ixx="${Ix_body}" ixy="0.0" ixz="0.0"
                 iyy="${Iy_body}" iyz="0.0"
                 izz="${Iz_body}"/>
    </inertial>
</xacro:macro>

<!-- Inertia macro: wheel -->
<xacro:macro name="inertia_wheel">
    <inertial>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <mass value="${m2}"/>
        <inertia ixx="${Iz_wheel}" ixy="0.0" ixz="0.0"
                 iyy="${I_wheel}"  iyz="0.0"
                 izz="${I_wheel}"/>
    </inertial>
</xacro:macro>

<!-- ========== BASE ========== -->
<link name="base_footprint"/>

<joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${s1}" rpy="0 0 0"/>
</joint>

<!-- ========== BASE LINK ========== -->
<link name="base_link">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="${a} ${c} ${b}"/>
        </geometry>
        <material name="body_material">
            <color rgba="${body_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="${a} ${c} ${b}"/>
        </geometry>
    </collision>
    <xacro:inertia_body/>
</link>

<!-- ============================================================== -->
<!-- WHEELS                                                         -->
<!-- ============================================================== -->

<!-- FRONT LEFT WHEEL -->
<joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="front_left_wheel"/>
    <origin xyz="${s2} ${s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
</joint>

<link name="front_left_wheel">
    <visual name="tire">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
        <material name="wheel_material">
            <color rgba="${wheel_color}"/>
        </material>
    </visual>
    <visual name="rim">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d + 0.002}" radius="${r * 0.65}"/>
        </geometry>
        <material name="wheel_rim_material">
            <color rgba="${wheel_rim_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- FRONT RIGHT WHEEL -->
<joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="front_right_wheel"/>
    <origin xyz="${s2} ${-s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
</joint>

<link name="front_right_wheel">
    <visual name="tire">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
        <material name="wheel_material">
            <color rgba="${wheel_color}"/>
        </material>
    </visual>
    <visual name="rim">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d + 0.002}" radius="${r * 0.65}"/>
        </geometry>
        <material name="wheel_rim_material">
            <color rgba="${wheel_rim_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- REAR LEFT WHEEL -->
<joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_left_wheel"/>
    <origin xyz="${-s2} ${s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
</joint>

<link name="rear_left_wheel">
    <visual name="tire">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
        <material name="wheel_material">
            <color rgba="${wheel_color}"/>
        </material>
    </visual>
    <visual name="rim">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d + 0.002}" radius="${r * 0.65}"/>
        </geometry>
        <material name="wheel_rim_material">
            <color rgba="${wheel_rim_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- REAR RIGHT WHEEL -->
<joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_right_wheel"/>
    <origin xyz="${-s2} ${-s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
</joint>

<link name="rear_right_wheel">
    <visual name="tire">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
        <material name="wheel_material">
            <color rgba="${wheel_color}"/>
        </material>
    </visual>
    <visual name="rim">
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d + 0.002}" radius="${r * 0.65}"/>
        </geometry>
        <material name="wheel_rim_material">
            <color rgba="${wheel_rim_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- ============================================================== -->
<!-- RPI CAMERA                                                     -->
<!-- ============================================================== -->

<joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${camera_x} ${camera_y} ${camera_z}" rpy="0 1.5708 0"/>
</joint>

<link name="camera_link">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="0.025 0.025 0.009"/>
        </geometry>
        <material name="camera_material">
            <color rgba="${camera_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="0.025 0.025 0.009"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.003"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.000001" ixy="0" ixz="0"
                 iyy="0.000001" iyz="0"
                 izz="0.000001"/>
    </inertial>
</link>

<joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0.0045" rpy="-1.5708 0 -1.5708"/>
</joint>

<link name="camera_optical_frame"/>

<!-- ============================================================== -->
<!-- RPLIDAR A1                                                     -->
<!-- ============================================================== -->

<joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 ${lidar_mount_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
</joint>

<link name="lidar_link">
    <visual name="lidar_body">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${lidar_height}" radius="${lidar_radius}"/>
        </geometry>
        <material name="lidar_material">
            <color rgba="${lidar_color}"/>
        </material>
    </visual>
    <visual name="lidar_top">
        <origin rpy="0 0 0" xyz="0 0 ${lidar_height/2 - 0.005}"/>
        <geometry>
            <cylinder length="0.005" radius="0.03"/>
        </geometry>
        <material name="lidar_top_material">
            <color rgba="${lidar_top_color}"/>
        </material>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${lidar_height}" radius="${lidar_radius}"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.17"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0"
                 izz="0.0001"/>
    </inertial>
</link>

<!-- ============================================================== -->
<!-- GAZEBO LIDAR SENSOR - RAYS FROM TOP                            -->
<!-- ============================================================== -->

<gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
        <pose>0 0 ${lidar_height/4} 0 0 0</pose>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <topic>scan</topic>
        
        <frame_name>lidar_link</frame_name>
        
        <lidar>
            <scan>
                <horizontal>
                    <samples>720</samples>
                    <resolution>1</resolution>
                    <min_angle>-3.14159</min_angle>
                    <max_angle>3.14159</max_angle>
                </horizontal>
                <vertical>
                    <samples>1</samples>
                    <resolution>0.01</resolution>
                    <min_angle>0</min_angle>
                    <max_angle>0</max_angle>
                </vertical>
            </scan>
            <range>
                <min>0.05</min>
                <max>12.0</max>
                <resolution>0.01</resolution>
            </range>
            <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.001</stddev>
            </noise>
        </lidar>
    </sensor>
</gazebo>

<!-- ============================================================== -->
<!-- GAZEBO CONFIGURATIONS                                          -->
<!-- ============================================================== -->

<gazebo reference="front_left_wheel">
    <mu1>0.8</mu1>
    <mu2>0.05</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/DarkGrey</material>
</gazebo>

<gazebo reference="front_right_wheel">
    <mu1>0.8</mu1>
    <mu2>0.05</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/DarkGrey</material>
</gazebo>

<gazebo reference="rear_left_wheel">
    <mu1>0.8</mu1>
    <mu2>0.05</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/DarkGrey</material>
</gazebo>

<gazebo reference="rear_right_wheel">
    <mu1>0.8</mu1>
    <mu2>0.05</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/DarkGrey</material>
</gazebo>

<gazebo reference="base_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Black</material>
</gazebo>

<!-- ============================================================== -->
<!-- SENSORS SYSTEM PLUGIN                                         -->
<!-- ============================================================== -->

<gazebo>
    <plugin
        filename="gz-sim-sensors-system"
        name="gz::sim::systems::Sensors">
        <render_engine>ogre2</render_engine>
    </plugin>
</gazebo>

<!-- ============================================================== -->
<!-- ROS2 CONTROL PLUGIN - THIS PROVIDES ODOMETRY                  -->
<!-- ============================================================== -->

<gazebo>
    <plugin filename="gz-ros2-control-system" name="gz::ros2_control::GazeboSimSystem">
        <parameters>$(find rover_description)/config/controller.yaml</parameters>
        <use_sim_time>true</use_sim_time>
    </plugin>
</gazebo>

</robot>
